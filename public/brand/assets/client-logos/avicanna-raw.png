<script defer>
// Select the image with the class "this-class"
let image = document.querySelector('.raven-side-menu-logo-link .raven-nav-menu-logo-mobile');

// Check if the image exists
if (image) {
  // Replace "http" with "https" in the src attribute if it starts with "http"
  if (image.src.startsWith('http:')) {
    image.src = image.src.replace('http:', 'https:');
  }

  // Replace "http" with "https" in the srcset attribute if it starts with "http"
  if (image.srcset) {
    image.srcset = image.srcset.split(',').map(src => src.trim().startsWith('http:') ? src.replace('http:', 'https:') : src).join(', ');
  }
}
</script><script>(function() {function maybePrefixUrlField() {
	if (this.value.trim() !== '' && this.value.indexOf('http') !== 0) {
		this.value = "http://" + this.value;
	}
}

var urlFields = document.querySelectorAll('.mc4wp-form input[type="url"]');
if (urlFields) {
	for (var j=0; j < urlFields.length; j++) {
		urlFields[j].addEventListener('blur', maybePrefixUrlField);
	}
}
})();</script>					<script type="text/x-template" id="mobile-menu-item-template"><li
